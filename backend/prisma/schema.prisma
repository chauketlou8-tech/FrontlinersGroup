datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Grade {
  GRADE10 @map("Grade 10")
  GRADE11 @map("Grade 11")
  GRADE12 @map("Grade 12")
}

enum Role {
  SUPER
  ADMIN
  VIEWER
}

enum Status {
  PENDING
  PAID
  OVERDUE
}

model ContactDetails {
  id      Int       @id @default(autoincrement())
  phone   String
  email   String?   @unique
  student Student   @relation(fields: [studentId], references: [id])
  studentId Int     @unique
}

model Student {
  id             Int             @id @default(autoincrement())
  name           String
  grade          Grade
  subject        String[]
  contactDetails ContactDetails?
  Enrollment     Enrollment?
  Payments       Payments[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Enrollment {
  id        Int     @id @default(autoincrement())
  student   Student @relation(fields: [studentId], references: [id])
  studentId Int     @unique
  selectedSubjects String[]
  grade     Grade
}

model Payments {
  id        Int     @id @default(autoincrement())
  student   Student @relation(fields: [studentId], references: [id])
  studentId Int
  Month     String
  Amount    Decimal
  PaymentMethod String
  ReferenceNumber String
  status    Status
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id         Int @id @default(autoincrement())
  name       String
  email      String @unique
  hashed_password String
  role Role @default(VIEWER)
}

model Sessions {
  id Int @id @default(autoincrement())
  user_id Int @unique
  refresh_token String @unique
  expires_at DateTime
}